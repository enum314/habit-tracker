{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "name": "@acme/web",
  "version": "0.0.1",
  "type": "module",
  "prettier": "@acme/prettier-config/next",
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "dev": "NODE_OPTIONS='--no-deprecation' next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@acme/components": "workspace:*",
    "@acme/hooks": "workspace:*",
    "@acme/marketing": "workspace:*",
    "@acme/seo": "workspace:*",
    "@acme/utils": "workspace:*",
    "@daveyplate/better-auth-ui": "^3.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-safe-action": "^8.5.3",
    "next-themes": "^0.4.6",
    "rate-limiter-flexible": "^11.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
