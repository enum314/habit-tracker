{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@acme/utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "prettier": "@acme/prettier-config/next",
  "exports": {
    "./cn": "./src/cn.ts",
    "./url": "./src/url.ts",
    "./string": "./src/string.ts",
    "./formatters": "./src/formatters.ts",
    "./currency": "./src/currency.ts",
    "./safe-redirect-path": "./src/safe-redirect-path.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
