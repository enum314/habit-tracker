{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@acme/seo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "prettier": "@acme/prettier-config/next",
  "exports": {
    "./create-seo-config": "./src/create-seo-config.ts",
    "./metadata": "./src/metadata.ts",
    "./robots": "./src/robots.ts",
    "./json-ld": "./src/json-ld.tsx",
    "./og-route": "./src/og-route.tsx",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "schema-dts": "^2.0.0"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^6.0.3"
  }
