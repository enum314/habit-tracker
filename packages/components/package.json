{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@acme/components",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "prettier": "@acme/prettier-config/next",
  "exports": {
    "./ui/*": "./src/ui/*.tsx",
    "./theme-provider": "./src/theme-provider.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@acme/hooks": "workspace:*",
    "@acme/utils": "workspace:*",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^9.14.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
